{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/server",
    "rootDir": "src",
    "declaration": false,
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["src/server/**/*", "src/storage/**/*", "src/shared/**/*"]
}
